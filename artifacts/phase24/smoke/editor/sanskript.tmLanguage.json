{
  "name": "Sanskript",
  "scopeName": "source.sanskript",
  "fileTypes": [
    "ssk",
    "sskm"
  ],
  "patterns": [
    {
      "name": "comment.line.double-slash.sanskript",
      "match": "//.*$"
    },
    {
      "name": "constant.language.boolean.sanskript",
      "match": "\\b(satyam|asatyam)\\b"
    },
    {
      "name": "keyword.control.sanskript",
      "match": "\\b(yadi|anyathﾄ－ﾄ“rahﾄｫtvﾄ－antam|vik盪｣epa盧･)\\b"
    },
    {
      "name": "keyword.other.sanskript",
      "match": "\\b(ga盪㌢ka盧･|ﾄ”vﾄ］am|samﾅｫha盧･|varga盧･)\\b"
    },
    {
      "name": "punctuation.terminator.sanskript",
      "match": "[.爭､]"
    }
  ]
}
