{
  "version": 1,
  "description": "Canonical Sanskript type and data-structure registry for surakṣita, rakṣita, and arakṣita tiers.",
  "safety_tiers": {
    "surakshita": {
      "iast": "surakṣita",
      "gloss": "fully checked ownership, lifetimes, effects, and memory regions",
      "analogy": "managed high-level (Python-like guarantees with Sanskrit grammar)"
    },
    "rakshita": {
      "iast": "rakṣita",
      "gloss": "explicit ownership transfer, borrowing, mutation, and release",
      "analogy": "Rust/C with checked declarations"
    },
    "arakshita": {
      "iast": "arakṣita",
      "gloss": "raw pointers, address arithmetic, layout, unchecked calls",
      "analogy": "machine-facing unsafe surface"
    }
  },
  "karaka_roles_for_types": {
    "karman": "value payload or element type",
    "karaṇa": "tool, index, key, or comparator",
    "adhikaraṇa": "storage locus, container, or memory region",
    "sampradāna": "destination, recipient, or transfer target",
    "apādāna": "source, release boundary, or lower bound",
    "genitive": "ownership, field path, or module membership"
  },
