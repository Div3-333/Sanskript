{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanskript.dev/schemas/bytecode-v2.json",
  "title": "Sanskript Bytecode v2",
  "type": "object",
  "required": ["version", "instructions"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instruction" }
    },
    "functions": {
      "type": "array",
      "items": { "$ref": "#/$defs/function" }
    },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/$defs/module" }
    },
    "safety_tier": {
      "type": "string",
      "enum": ["surakshita", "rakshita", "arakshita"]
    }
  },
  "$defs": {
    "instruction": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "push_int",
            "push_text",
            "push_bool",
            "text_concat",
            "text_len",
            "text_get",
            "text_slice",
            "text_contains",
            "list_new",
            "list_append",
            "list_len",
            "list_get",
            "map_new",
            "map_set",
            "map_get",
            "map_contains",
            "record_new",
            "record_set",
            "record_get",
            "record_contains",
            "push_float",
            "heap_alloc",
            "heap_store",
            "heap_load",
            "heap_free",
            "unsafe_enter",
            "unsafe_exit",
            "load_name",
            "store_name",
            "add",
            "subtract",
            "multiply",
            "divide",
            "compare_eq",
            "compare_lt",
            "emit",
            "jump",
            "jump_if_zero",
            "call",
            "return",
            "pop",
            "halt"
          ]
        },
        "operand": {}
      },
      "allOf": [
        {
          "if": { "properties": { "op": { "enum": ["push_int", "push_bool"] } } },
          "then": { "required": ["operand"], "properties": { "operand": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "op": { "const": "push_text" } } },
          "then": { "required": ["operand"], "properties": { "operand": { "type": "string" } } }
        },
        {
          "if": { "properties": { "op": { "const": "push_float" } } },
          "then": { "required": ["operand"], "properties": { "operand": { "type": "number" } } }
        },
        {
          "if": {
            "properties": {
              "op": { "enum": ["load_name", "store_name", "call"] }
            }
          },
          "then": {
            "required": ["operand"],
            "properties": { "operand": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "if": {
            "properties": { "op": { "enum": ["jump", "jump_if_zero"] } }
          },
          "then": {
            "required": ["operand"],
            "properties": { "operand": { "type": "integer" } }
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "enum": [
                  "list_new",
                  "text_concat",
                  "text_len",
                  "text_get",
                  "text_slice",
                  "text_contains",
                  "list_append",
                  "list_len",
                  "list_get",
                  "map_new",
                  "map_set",
                  "map_get",
                  "map_contains",
                  "record_new",
                  "record_set",
                  "record_get",
                  "record_contains",
                  "heap_alloc",
                  "heap_store",
                  "heap_load",
                  "heap_free",
                  "unsafe_enter",
                  "unsafe_exit",
                  "add",
                  "subtract",
                  "multiply",
                  "divide",
                  "compare_eq",
                  "compare_lt",
                  "emit",
                  "return",
                  "pop",
                  "halt"
                ]
              }
            }
          },
          "then": { "not": { "required": ["operand"] } }
        }
      ]
    },
    "function": {
      "type": "object",
      "required": ["name", "instructions"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "params": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "instructions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/instruction" }
        }
      }
    },
    "module": {
      "type": "object",
      "required": ["name", "functions"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "functions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/function" }
        }
      }
    }
  }
}
